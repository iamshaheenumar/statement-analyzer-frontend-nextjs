generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Statement {
  id          String    @id
  userId      String
  bank        String
  from_date   DateTime?
  to_date     DateTime?
  card_type   String?
  currency    String    @default("AED")
  recordCount Int
  totalDebit  Decimal
  totalCredit Decimal
  netChange   Decimal
  createdAt   DateTime  @default(now())

  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          Int       @id @default(autoincrement())
  statementId String
  statement   Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  transactionDate DateTime?
  description     String?
  debit           Decimal?
  credit          Decimal?
  amount          Decimal?
  bank            String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
}

model BankCard {
  id         String   @id @default(uuid())
  userId     String
  bank       String
  cardNumber String?
  cardType   String
  password   String?
  nickname   String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model ParserConfig {
  id             String   @id @default(uuid())
  userId         String?
  bank           String
  keywords       String[]
  config         Json
  source         String   @default("ai")
  active         Boolean  @default(true)
  status         String   @default("pending")
  rawPageContent Json?
  createdAt      DateTime @default(now())

  @@index([userId])
}

model AdminSetting {
  key   String @id
  value Json
}

model Category {
  id        String   @id @default(uuid())
  userId    String?
  name      String
  color     String
  icon      String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  transactions Transaction[]
  mappings     DescriptionCategoryMap[]

  @@index([userId])
}

model DescriptionCategoryMap {
  id          String   @id @default(uuid())
  userId      String?
  description String
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  source      String   @default("ai")
  createdAt   DateTime @default(now())

  @@index([userId, description])
  @@index([description])
}
