generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Statement {
  id          String    @id
  userId      String
  bank        String
  from_date   DateTime?
  to_date     DateTime?
  card_type   String?
  currency    String    @default("AED")
  recordCount Int
  totalDebit  Decimal
  totalCredit Decimal
  netChange   Decimal
  createdAt   DateTime  @default(now())

  transactions Transaction[]

  @@index([userId])
}

model Transaction {
  id          Int       @id @default(autoincrement())
  statementId String
  statement   Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)

  transactionDate DateTime?
  description     String?
  debit           Decimal?
  credit          Decimal?
  amount          Decimal?
  bank            String?
}

model BankCard {
  id         String   @id @default(uuid())
  userId     String
  bank       String
  cardNumber String?
  cardType   String
  password   String?
  nickname   String?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model ParserConfig {
  id        String   @id @default(uuid())
  userId    String?
  bank      String
  keywords  String[]
  config    Json
  source    String   @default("ai")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([userId])
}
